<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nimbus Drive</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet">
<link rel="stylesheet" href="/styles/app.css">
</head>
<body class="app-shell">
<div class="orb orb-one"></div>
<div class="orb orb-two"></div>
<div class="orb orb-three"></div>

<%
const totalSizeBytes = files.reduce((sum, file) => sum + (file.size || 0), 0);
const imageCount = files.filter(file => /\.(png|jpg|jpeg|gif|webp)$/i.test(file.originalname)).length;
const latestFile = files.length ? files.reduce((latest, current) => new Date(current.createdAt) > new Date(latest.createdAt) ? current : latest) : null;
const totalSizeMb = (totalSizeBytes / (1024 * 1024)).toFixed(2);
%>

<main class="dashboard-layout">
  <section class="dashboard-card animate-rise">
    <div class="dashboard-topbar">
      <div>
        <a href="/home" class="brand">
          <span class="brand-badge"><i class="ri-hard-drive-3-line"></i></span>
          <span>NIMBUS DRIVE</span>
        </a>
        <h1 class="dashboard-title">A cleaner place for your files.</h1>
        <p class="hero-copy max-w-3xl">
          Upload, preview, download, and share everything from a dashboard designed to feel lighter and easier to scan.
        </p>
      </div>

      <a href="/user/logout" class="button-danger">
        <i class="ri-logout-box-r-line"></i>
        Logout
      </a>
    </div>

    <div class="dashboard-metrics">
      <div class="metric-card">
        <span class="metric-label">Total files</span>
        <strong class="metric-value"><%= files.length %></strong>
      </div>
      <div class="metric-card">
        <span class="metric-label">Library size</span>
        <strong class="metric-value"><%= totalSizeMb %> MB</strong>
      </div>
      <div class="metric-card">
        <span class="metric-label">Images stored</span>
        <strong class="metric-value"><%= imageCount %></strong>
      </div>
    </div>

    <div class="dashboard-toolbar">
      <button onclick="scrollToUpload()" class="button-primary" type="button">
        <i class="ri-upload-cloud-2-line"></i>
        Upload File
      </button>

      <label class="search-wrap">
        <i class="ri-search-line"></i>
        <input type="text" id="search" placeholder="Search files, dates, or size..." />
      </label>
    </div>

    <div class="dashboard-content">
      <aside class="upload-panel animate-rise" id="uploadSection" style="animation-delay: 0.12s;">
        <span class="eyebrow">
          <i class="ri-add-circle-line"></i>
          Quick upload
        </span>
        <h2 class="text-2xl font-semibold mt-5">Drop in your next file</h2>
        <p class="muted mt-3">
          Pick a document, image, or download and it will appear in your library right away.
        </p>

        <form id="uploadForm" action="/upload-file" method="POST" enctype="multipart/form-data" class="mt-6">
          <label for="dropzone-file" class="upload-dropzone">
            <input name="file" id="dropzone-file" type="file" required>
            <div class="upload-copy">
              <i class="ri-upload-cloud-2-line"></i>
              <h3 class="text-xl font-semibold mt-4">Choose a file or drag it here</h3>
              <p class="muted mt-2">Supports PNG, JPG, PDF, and other common file types.</p>
              <p class="hint mt-3" id="selectedFileText">No file selected yet</p>
            </div>
          </label>

          <button type="submit" class="button-primary w-full mt-5">
            <i class="ri-send-plane-2-line"></i>
            Upload now
          </button>

          <div id="progressContainer" class="progress-track hidden">
            <div id="progressBar" class="progress-fill">0%</div>
          </div>
        </form>

        <div class="mt-6">
          <p class="hint">Latest upload</p>
          <p class="mt-2 font-medium"><%= latestFile ? latestFile.originalname : "Nothing uploaded yet" %></p>
        </div>
      </aside>

      <section class="animate-rise" style="animation-delay: 0.18s;">
        <% if(files.length === 0) { %>
          <div class="empty-state">
            <i class="ri-folder-open-line"></i>
            <h3 class="text-2xl font-semibold text-white">Your library is empty</h3>
            <p class="mt-3 max-w-xl mx-auto">Start by uploading your first file and this dashboard will fill in with previews, metadata, and quick actions.</p>
          </div>
        <% } else { %>
          <div class="files-grid">
            <% files.forEach(file => { %>
              <div class="file-card">
                <div class="file-main">
                  <div class="file-name">
                    <% if(/\.(png|jpg|jpeg|gif|webp)$/i.test(file.originalname)) { %>
                      <i class="ri-image-line" style="color:#4fd1c5;"></i>
                    <% } else if(/\.(pdf)$/i.test(file.originalname)) { %>
                      <i class="ri-file-pdf-line" style="color:#ff8e72;"></i>
                    <% } else { %>
                      <i class="ri-file-line" style="color:#a8b7d8;"></i>
                    <% } %>
                    <span><%= file.originalname %></span>
                  </div>

                  <div class="file-meta">
                    <span class="chip">
                      <i class="ri-database-2-line"></i>
                      <%= file.size ? (file.size / 1024).toFixed(2) : "0.00" %> KB
                    </span>
                    <span class="chip">
                      <i class="ri-time-line"></i>
                      <%= new Date(file.createdAt).toLocaleString() %>
                    </span>
                  </div>
                </div>

                <div class="file-actions">
                  <a href="<%= file.path %>" target="_blank" class="button-secondary">
                    <i class="ri-eye-line"></i>
                    View
                  </a>

                  <a href="<%= file.path.replace('/upload/','/upload/fl_attachment/') %>" class="button-primary">
                    <i class="ri-download-line"></i>
                    Download
                  </a>

                  <button onclick="copyLink('<%= file._id %>')" class="button-ghost" type="button">
                    <i class="ri-share-forward-line"></i>
                    Copy link
                  </button>

                  <a href="/delete/<%= file._id %>" class="button-danger">
                    <i class="ri-delete-bin-line"></i>
                    Delete
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </section>
</main>

<script>
const search = document.getElementById("search");
const fileInput = document.getElementById("dropzone-file");
const selectedFileText = document.getElementById("selectedFileText");
const form = document.getElementById("uploadForm");

search.addEventListener("keyup", function () {
  const value = this.value.toLowerCase();
  const rows = document.querySelectorAll(".file-card");

  rows.forEach((row) => {
    const name = row.innerText.toLowerCase();
    row.style.display = name.includes(value) ? "" : "none";
  });
});

fileInput.addEventListener("change", function () {
  selectedFileText.textContent = this.files.length ? this.files[0].name : "No file selected yet";
});

function copyLink(id) {
  const link = window.location.origin + "/share/" + id;
  navigator.clipboard.writeText(link);
  alert("Share link copied!");
}

function scrollToUpload() {
  document.getElementById("uploadSection").scrollIntoView({ behavior: "smooth", block: "start" });
}

form.addEventListener("submit", function (e) {
  e.preventDefault();

  const formData = new FormData(form);
  const xhr = new XMLHttpRequest();

  xhr.open("POST", "/upload-file");

  document.getElementById("progressContainer").style.display = "block";
  document.getElementById("progressContainer").classList.remove("hidden");

  xhr.upload.addEventListener("progress", function (e) {
    if (e.lengthComputable) {
      const percent = Math.round((e.loaded / e.total) * 100);
      const bar = document.getElementById("progressBar");

      bar.style.width = percent + "%";
      bar.innerText = percent + "%";
    }
  });

  xhr.onload = function () {
    window.location.reload();
  };

  xhr.send(formData);
});
</script>

</body>
</html>
